import UIKit
import CoreData

class ViewController: UIViewController, UITableViewDelegate, UITableViewDataSource {

    // MARK: - OUTLETS
    @IBOutlet weak var name: UITextField!
    @IBOutlet weak var age: UITextField!
    @IBOutlet weak var number: UITextField!
    @IBOutlet weak var tableview: UITableView!
    @IBOutlet weak var btn: UIButton!

    // MARK: - CORE DATA
    let context = (UIApplication.shared.delegate as! AppDelegate).persistentContainer.viewContext

    var arrdata: [Person] = []
    var selectPerson: Person?

    // MARK: - LOAD
    override func viewDidLoad() {
        super.viewDidLoad()
        fetchData()
    }

    // MARK: - INSERT + UPDATE
    @IBAction func insertData(_ sender: UIButton) {

        if let person = selectPerson {
            // UPDATE
            person.name = name.text
            person.age = Int16(age.text ?? "") ?? 0
            person.number = Int32(number.text ?? "") ?? 0

        } else {
            // INSERT
            let newPerson = Person(context: context)
            newPerson.name = name.text
            newPerson.age = Int16(age.text ?? "") ?? 0
            newPerson.number = Int32(number.text ?? "") ?? 0
            newPerson.id = UUID()
        }

        try? context.save()

        fetchData()
        clearData()

        selectPerson = nil
        btn.setTitle("Insert", for: .normal)

        showAlert(message: "Saved Successfully")
    }

    // MARK: - FETCH
    func fetchData() {
        let request: NSFetchRequest<Person> = Person.fetchRequest()

        do {
            arrdata = try context.fetch(request)
        } catch {
            print("Fetch Error")
        }

        tableview.reloadData()
    }

    // MARK: - CLEAR
    func clearData() {
        name.text = ""
        age.text = ""
        number.text = ""
    }

    // MARK: - TABLE VIEW

    func tableView(_ tableView: UITableView, numberOfRowsInSection section: Int) -> Int {
        return arrdata.count
    }

    func tableView(_ tableView: UITableView,
                   cellForRowAt indexPath: IndexPath) -> UITableViewCell {

        let cell = tableView.dequeueReusableCell(withIdentifier: "cell", for: indexPath)
        let data = arrdata[indexPath.row]

        cell.textLabel?.text = data.name
        cell.detailTextLabel?.text = "Age: \(data.age), No: \(data.number)"

        return cell
    }

    // MARK: - DELETE
    func tableView(_ tableView: UITableView,
                   commit editingStyle: UITableViewCell.EditingStyle,
                   forRowAt indexPath: IndexPath) {

        if editingStyle == .delete {
            context.delete(arrdata[indexPath.row])
            try? context.save()
            fetchData()
        }
    }

    // MARK: - SELECT + NAVIGATION
    func tableView(_ tableView: UITableView, didSelectRowAt indexPath: IndexPath) {

        let data = arrdata[indexPath.row]
        selectPerson = data

        name.text = data.name
        age.text = "\(data.age)"
        number.text = "\(data.number)"

        btn.setTitle("Update", for: .normal)

        // Navigate to next screen
        performSegue(withIdentifier: "next", sender: data)
    }

    // MARK: - PASS DATA
    override func prepare(for segue: UIStoryboardSegue, sender: Any?) {

        if segue.identifier == "next" {
            let vc = segue.destination as! DetailViewController
            vc.person = sender as? Person
        }
    }

    // MARK: - ALERT
    func showAlert(message: String) {
        let alert = UIAlertController(title: "Success",
                                      message: message,
                                      preferredStyle: .alert)

        alert.addAction(UIAlertAction(title: "OK", style: .default))
        self.present(alert, animated: true)
    }
}



import UIKit

class DetailViewController: UIViewController {

    @IBOutlet weak var nameLabel: UILabel!
    @IBOutlet weak var ageLabel: UILabel!
    @IBOutlet weak var numberLabel: UILabel!

    var person: Person?

    override func viewDidLoad() {
        super.viewDidLoad()

        nameLabel.text = person?.name
        ageLabel.text = "Age: \(person?.age ?? 0)"
        numberLabel.text = "No: \(person?.number ?? 0)"
    }
}
